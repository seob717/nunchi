#!/usr/bin/env python3
"""mock gh — 진짜 GitHub 호출 없이 `gh pr create`의 제목/본문을 캡처한다."""
import sys, json, os, time

args = sys.argv[1:]


def flag_value(name, short=None):
    for i, a in enumerate(args):
        if a == name or (short and a == short):
            return args[i + 1] if i + 1 < len(args) else None
        if a.startswith(name + "="):
            return a.split("=", 1)[1]
    return None


if args[:2] == ["pr", "create"]:
    title = flag_value("--title", "-t")
    body = flag_value("--body", "-b")
    body_file = flag_value("--body-file", "-F")
    if body is None and body_file:
        try:
            src = sys.stdin if body_file == "-" else open(body_file)
            body = src.read()
        except OSError:
            body = None
    capture = {"title": title, "body": body, "argv": args, "ts": time.time()}
    out_dir = os.environ.get("GH_CAPTURE_DIR", "/tmp/gh-capture")
    os.makedirs(out_dir, exist_ok=True)
    path = os.path.join(out_dir, f"pr-{int(time.time() * 1000)}.json")
    with open(path, "w") as f:
        json.dump(capture, f, ensure_ascii=False, indent=2)
    print("https://github.com/lab/pilot/pull/1")
    sys.exit(0)

if args[:2] == ["auth", "status"]:
    print("github.com: Logged in as lab-bot (mock)")
    sys.exit(0)

if args[:2] == ["repo", "view"]:
    print("lab/pilot (mock)")
    sys.exit(0)

print("mock gh: ok")
sys.exit(0)
